# --- Secrets: never commit real credentials ---
creds/
*.env
!creds_template.env
.Renviron
.httr-oauth

# --- Data (regenerated by the pull scripts; Revelio/WRDS data is licensed) ---
# Everything in data/ is transient and re-fetched by the cloud build, EXCEPT
# the TSA file: tsa.gov blocks the cloud runner, so a local scheduled job
# scrapes TSA and commits this one file for the build to read.
data/*
!data/tsa/
data/tsa/*
!data/tsa/tsa_daily_passenger_volumes.csv

# --- R session artifacts (can hold API keys / clutter the repo) ---
.RData
.RDataTmp
.Rhistory
.Rapp.history
.Rproj.user/
.Ruserdata
rsconnect/

# --- knitr / R Markdown caches ---
*_cache/
/cache/
*.utf8.md
*.knit.md

# --- OS / editor junk ---
.DS_Store
*~

# --- Local Claude Code config ---
.claude/

# Quarto website output
/_site/
/.quarto/

**/*.quarto_ipynb
