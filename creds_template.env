# Economic Snapshot — Credential Template
#
# Copy this file to ~/Desktop/econ_indicator_dashboard/creds/ and fill in real values.
# That directory is outside the git repo, so keys are never committed.
#
# FRED API key  →  https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BLS API key   →  https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# WRDS credentials (used only for wrds_revelio_pull.R — requires 2FA on first run)
WRDS_USER=your_wrds_username_here
WRDS_PASSWORD=your_wrds_password_here
